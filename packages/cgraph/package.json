{
  "name": "cgraph",
  "version": "0.1.0",
  "description": "A layer: ephemeral graph lens over an outline + checked JSX projection (round-trip law)",
  "type": "module",
  "bin": {
    "cgraph": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.39.5",
    "component-outline": "workspace:*",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
